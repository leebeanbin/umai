# ── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=false

# 배포 시 실제 도메인으로 변경
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# 로컬: docker run -e POSTGRES_USER=umai -e POSTGRES_PASSWORD=umai -e POSTGRES_DB=umai -p 5432:5432 postgres:16
DATABASE_URL=postgresql+asyncpg://umai:umai@localhost:5432/umai

# ── Redis ─────────────────────────────────────────────────────────────────────
# 로컬: docker run -p 6379:6379 redis:7
REDIS_URL=redis://localhost:6379/0

# ── Kafka ─────────────────────────────────────────────────────────────────────
# 로컬 docker-compose 사용 시
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_USE_SASL=false

# Upstash Kafka (프로덕션) — fly secrets set 또는 환경변수로 주입
# KAFKA_BOOTSTRAP_SERVERS=your-endpoint.upstash.io:9092
# KAFKA_USE_SASL=true
# KAFKA_SASL_USERNAME=your-upstash-username
# KAFKA_SASL_PASSWORD=your-upstash-password

# ── OAuth ─────────────────────────────────────────────────────────────────────
# Google: https://console.cloud.google.com/apis/credentials
#   → OAuth 2.0 Client ID 생성 (Web application)
#   → Authorized redirect URIs: http://localhost:8000/api/v1/auth/oauth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub: https://github.com/settings/applications/new
#   → Authorization callback URL: http://localhost:8000/api/v1/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── LLM (서버사이드) ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
